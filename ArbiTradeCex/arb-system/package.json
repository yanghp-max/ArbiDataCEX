{
  "name": "arbitradecex",
  "version": "0.1.0",
  "description": "CEX-CEX arbitrage (Binance PM + Gate unified)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dry": "npm run build:dashboard && node strategies/cex-cex-multi-strategy.js --dry",
    "live": "npm run build:dashboard && node strategies/cex-cex-multi-strategy.js --live",
    "start": "npm run dry",
    "build:dashboard": "npm install --prefix dashboard/frontend && npm run build --prefix dashboard/frontend",
    "dev:dashboard": "npm run dev --prefix dashboard/frontend",
    "fetch:min-qty": "node scripts/fetch-min-order-qty.js",
    "build:symbols-min-qty": "node scripts/build-common-min-order-qty.js"
  },
  "dependencies": {
    "async-mutex": "^0.5.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "ws": "^8.18.0"
  }
}
